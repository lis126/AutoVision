# Copy to .env or run:
# python scripts/run_batch.py configure

# Shared OpenAI-compatible API base URL and key for text + image calls.
AD_API_BASE_URL="https://your-platform.example/v1"
AD_API_KEY="replace-with-your-api-key"

# Default image model. Override only if your platform uses a different name.
AD_IMAGE_MODEL="gpt-image-2-all"

# Default reasoning model for template -> final_prompt fallback.
AD_TEXT_MODEL="gpt-5.4"

# Use "none" if the image API rejects OpenAI-style response_format.
AD_IMAGE_RESPONSE_FORMAT="b64_json"
